# --- SYSTEM CONFIG ---
HOSTNAME=vps-host

# --- POSTGRES CONFIG ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_with_secure_password
POSTGRES_DB=postgres
# Comma-separated list of additional databases to create
POSTGRES_MULTIPLE_DATABASES=postly,learnest

# --- REDIS CONFIG ---
REDIS_PASSWORD=replace_with_secure_password

# --- GRAFANA CONFIG ---
GF_SECURITY_ADMIN_PASSWORD=replace_with_secure_password
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url

# --- VICTORIA METRICS/LOGS ---
# No external auth by default as they are internal-only
# but you can add basic auth if exposing them.
